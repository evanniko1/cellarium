# Copy to .env and fill in. The demo agent uses the Anthropic Messages API.
ANTHROPIC_API_KEY=
# Optional: override the default model.
CELLARIUM_MODEL=claude-sonnet-4-5
# HF raw downloads are ON by default (the raw corpus is uploaded). Set to 0 to force regenerate-locally instead.
# CELLARIUM_HF_HAS_RAW=0
