# Copy to .env and fill in. The demo agent uses the Anthropic Messages API.
ANTHROPIC_API_KEY=
# Optional: override the default model.
CELLARIUM_MODEL=claude-sonnet-4-5
# Set to 1 ONCE the raw simOut is uploaded to the HF dataset — enables download_raw / data_availability to offer
# HF pulls (otherwise the agent honestly reports HF as unavailable and points to regenerate-locally).
CELLARIUM_HF_HAS_RAW=1
